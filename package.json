{
  "name": "finch-app",
  "version": "1.0.0",
  "description": "Offline-first desktop invoice generator",
  "main": "dist/main/main.js",
  "scripts": {
    "test": "vitest --run",
    "build:main": "webpack --config webpack.main.config.js --mode production",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build": "npm run build:main && npm run build:renderer",
    "watch:main": "webpack --config webpack.main.config.js --watch --mode development",
    "watch:renderer": "webpack --config webpack.renderer.config.js --watch --mode development",
    "start:electron": "wait-on dist/main/main.js dist/renderer/index.html && electron .",
    "start": "cls && npm run build && electron .",
    "dev": "concurrently --kill-others-on-fail \"npm run watch:main\" \"npm run watch:renderer\" \"npm run start:electron\"",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "archiver": "^5.3.2",
    "electron-log": "^5.1.2",
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/archiver": "^5.3.4",
    "@types/node": "^20.11.5",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4"
  }
}
